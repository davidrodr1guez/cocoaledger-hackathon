# Google Gemini (free) — get key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Anthropic (Claude) — get key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# OpenAI — get key at https://platform.openai.com
OPENAI_API_KEY=
