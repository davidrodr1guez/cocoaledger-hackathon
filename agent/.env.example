# Public chain
PUBLIC_CHAIN_RPC_URL=https://testnet-rpc.rayls.com

# Contracts
TOKEN_ADDRESS=0x
ATTESTATION_ADDRESS=0x

# Agent wallet (needs gas on public chain)
AGENT_PRIVATE_KEY=0x

# AI provider: "gemini" (free tier), "anthropic", or "openai"
